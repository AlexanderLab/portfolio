rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para Artículos
    match /articles/{article} {
      allow read: if true;
      // Permitir crear, borrar y actualizar a cualquier usuario autenticado (según tu código)
      allow create, delete, update: if request.auth != null;
    }

    // Reglas para la Galería
    match /gallery/{imageId} {
      allow read: if true;
      // Solo admin puede escribir en galería
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Reglas para Comentarios
    match /comments/{commentId} {
      allow read: if true;
      
      // Permitir crear a cualquier usuario autenticado
      allow create: if request.auth != null;
                   
      // Solo el autor o un admin pueden borrar
      allow delete: if request.auth != null 
                   && (request.resource.data.userId == request.auth.uid || request.auth.token.admin == true);
    }
    
    // Bloquear todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
